---
import { NAVIGATION, SITE, SOCIAL_LINKS } from '@config/site';
import { Rocket, Linkedin, Facebook, Instagram, MessageCircle, Phone } from 'lucide-react';

const phoneRaw = SITE.whatsapp.replace(/\D/g, '');
const phoneHref = `tel:+${phoneRaw}`;

const phoneDisplay =
  phoneRaw.startsWith('56') && phoneRaw.length === 11
    ? `+${phoneRaw.slice(0, 2)} ${phoneRaw.slice(2, 3)} ${phoneRaw.slice(3, 7)} ${phoneRaw.slice(7)}`
    : `+${phoneRaw}`;

const whatsappUrl = `https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent('Hola, quiero cotizar una página web profesional con Google Ads')}`;
---

<footer class="bg-slate-950 text-slate-300">
  <div class="container mx-auto px-4 py-16 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-4">
      <div class="space-y-6 lg:col-span-1">
        <a href="/" class="group flex items-center space-x-3">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-linear-to-br from-blue-700 via-cyan-600 to-teal-500">
            <Rocket className="h-7 w-7 text-white" />
          </div>
          <span class="text-2xl font-black text-white">ImpulsoWebLocal</span>
        </a>

        <p class="max-w-xs text-sm leading-relaxed text-slate-400">
          Páginas web profesionales y campañas de Google Ads para negocios locales que quieren recibir más consultas por WhatsApp o llamada.
        </p>

        <div class="flex space-x-4">
          <a
            href={SOCIAL_LINKS.linkedin}
            class="flex h-10 w-10 items-center justify-center rounded-lg bg-slate-900 text-slate-400 transition-all hover:bg-blue-700 hover:text-white"
            aria-label="LinkedIn"
          >
            <Linkedin className="h-5 w-5" />
          </a>

          <a
            href={SOCIAL_LINKS.instagram}
            class="flex h-10 w-10 items-center justify-center rounded-lg bg-slate-900 text-slate-400 transition-all hover:bg-pink-600 hover:text-white"
            aria-label="Instagram"
          >
            <Instagram className="h-5 w-5" />
          </a>

          <a
            href={SOCIAL_LINKS.facebook}
            class="flex h-10 w-10 items-center justify-center rounded-lg bg-slate-900 text-slate-400 transition-all hover:bg-blue-600 hover:text-white"
            aria-label="Facebook"
          >
            <Facebook className="h-5 w-5" />
          </a>
        </div>
      </div>

      <div>
        <h3 class="mb-6 text-sm font-semibold uppercase tracking-wider text-white">
          Navegación
        </h3>

        <ul class="space-y-3">
          {NAVIGATION.map((item) => (
            <li>
              <a
                href={item.href}
                class="group inline-flex items-center text-sm text-slate-400 transition-colors hover:text-cyan-300"
              >
                <span class="mr-0 h-0.5 w-0 bg-cyan-300 transition-all group-hover:mr-2 group-hover:w-2"></span>
                {item.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="mb-6 text-sm font-semibold uppercase tracking-wider text-white">
          Especialidades
        </h3>

        <ul class="space-y-3 text-sm text-slate-400">
          <li>Gasfitería, destapes y fugas</li>
          <li>Electricistas y urgencias</li>
          <li>Cerrajería 24 horas</li>
          <li>Control de plagas</li>
          <li>Climatización y servicios técnicos</li>
        </ul>
      </div>

      <div>
        <h3 class="mb-6 text-sm font-semibold uppercase tracking-wider text-white">
          Contacto
        </h3>

        <p class="mb-5 text-sm text-slate-400">
          Agenda una revisión rápida de tu idea y recibe una propuesta clara para captar clientes desde Google.
        </p>

        <div class="flex flex-col gap-3 sm:flex-row lg:flex-col xl:flex-row">
          <a
            href={phoneHref}
            aria-label={`Llamar a Impulso Web Local ${phoneDisplay}`}
            class="inline-flex items-center justify-center gap-2 rounded-xl bg-white px-6 py-3 text-sm font-bold text-slate-950 shadow-lg transition-all hover:-translate-y-0.5 hover:bg-cyan-50 hover:shadow-xl"
          >
            <Phone className="h-5 w-5" />
            Llamar
          </a>

          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center justify-center gap-2 rounded-xl bg-linear-to-r from-green-600 to-emerald-600 px-6 py-3 text-sm font-bold text-white shadow-lg transition-all hover:-translate-y-0.5 hover:from-green-700 hover:to-emerald-700 hover:shadow-xl"
          >
            <MessageCircle className="h-5 w-5" />
            WhatsApp
          </a>
        </div>
      </div>
    </div>

    <div class="mt-16 flex flex-col items-center justify-between gap-4 border-t border-slate-800 pt-8 text-sm text-slate-500 md:flex-row">
      <p>&copy; {new Date().getFullYear()} {SITE.author}. Todos los derechos reservados.</p>
      <p>Impulso Web Local · Páginas web profesionales + Google Ads para negocios locales.</p>
    </div>
  </div>
</footer>
