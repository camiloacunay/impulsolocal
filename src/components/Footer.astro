---
import { NAVIGATION, SITE, SOCIAL_LINKS } from '@config/site';
import { Rocket, Linkedin, Facebook, Instagram, MessageCircle } from 'lucide-react';
const whatsappUrl = `https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent('Hola, quiero cotizar una página web profesional con Google Ads')}`;
---

<footer class="bg-slate-950 text-slate-300">
  <div class="container mx-auto px-4 py-16 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-4">
      <div class="lg:col-span-1 space-y-6">
        <a href="/" class="flex items-center space-x-3 group">
          <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-linear-to-br from-blue-700 via-cyan-600 to-teal-500">
            <Rocket className="w-7 h-7 text-white" />
          </div>
          <span class="text-2xl font-black text-white">ImpulsoLocal</span>
        </a>
        <p class="text-sm text-slate-400 leading-relaxed max-w-xs">
          Páginas web profesionales y campañas de Google Ads para negocios locales que quieren recibir más consultas por WhatsApp o llamada.
        </p>
        <div class="flex space-x-4">
          <a href={SOCIAL_LINKS.linkedin} class="w-10 h-10 flex items-center justify-center rounded-lg bg-slate-900 text-slate-400 hover:bg-blue-700 hover:text-white transition-all" aria-label="LinkedIn"><Linkedin className="w-5 h-5" /></a>
          <a href={SOCIAL_LINKS.instagram} class="w-10 h-10 flex items-center justify-center rounded-lg bg-slate-900 text-slate-400 hover:bg-pink-600 hover:text-white transition-all" aria-label="Instagram"><Instagram className="w-5 h-5" /></a>
          <a href={SOCIAL_LINKS.facebook} class="w-10 h-10 flex items-center justify-center rounded-lg bg-slate-900 text-slate-400 hover:bg-blue-600 hover:text-white transition-all" aria-label="Facebook"><Facebook className="w-5 h-5" /></a>
        </div>
      </div>

      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white mb-6">Navegación</h3>
        <ul class="space-y-3">
          {NAVIGATION.map((item) => (
            <li><a href={item.href} class="text-sm text-slate-400 hover:text-cyan-300 transition-colors inline-flex items-center group"><span class="w-0 group-hover:w-2 h-0.5 bg-cyan-300 transition-all mr-0 group-hover:mr-2"></span>{item.name}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white mb-6">Especialidades</h3>
        <ul class="space-y-3 text-sm text-slate-400">
          <li>Gasfitería, destapes y fugas</li>
          <li>Electricistas y urgencias</li>
          <li>Cerrajería 24 horas</li>
          <li>Control de plagas</li>
          <li>Climatización y servicios técnicos</li>
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white mb-6">Contacto</h3>
        <p class="text-sm text-slate-400 mb-5">Agenda una revisión rápida de tu idea y recibe una propuesta clara para captar clientes desde Google.</p>
        <a href={whatsappUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-6 py-3 text-sm font-bold text-white bg-linear-to-r from-green-600 to-emerald-600 hover:from-green-700 hover:to-emerald-700 rounded-xl shadow-lg hover:shadow-xl transition-all">
          <MessageCircle className="w-5 h-5" /> WhatsApp
        </a>
      </div>
    </div>

    <div class="mt-16 pt-8 border-t border-slate-800 flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-slate-500">
      <p>&copy; {new Date().getFullYear()} {SITE.author}. Todos los derechos reservados.</p>
      <p>Hecho para GitHub Pages · Edita textos, número y marca en <code>src/config/site.ts</code></p>
    </div>
  </div>
</footer>
