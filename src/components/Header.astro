---
import { NAVIGATION, SITE } from '@config/site';
import { Rocket, Phone, MessageCircle } from 'lucide-react';
import MobileMenu from '@components/react/MobileMenu';

const { currentPathname } = Astro.props;

const normalize = (path: string) =>
  path.endsWith('/') && path !== '/' ? path.slice(0, -1) : path;

const isActiveLink = (href: string): boolean =>
  normalize(href) === normalize(currentPathname);

const phoneRaw = SITE.whatsapp.replace(/\D/g, '');
const phoneHref = `tel:+${phoneRaw}`;

const phoneDisplay =
  phoneRaw.startsWith('56') && phoneRaw.length === 11
    ? `+${phoneRaw.slice(0, 2)} ${phoneRaw.slice(2, 3)} ${phoneRaw.slice(3, 7)} ${phoneRaw.slice(7)}`
    : `+${phoneRaw}`;

const whatsappUrl = `https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent(
  'Hola, quiero cotizar una página web profesional con Google Ads'
)}`;
---

<header class="sticky top-0 z-50 w-full border-b border-slate-200 bg-white/95 shadow-sm backdrop-blur-md">
  <nav class="container mx-auto flex h-20 items-center justify-between px-4 sm:px-6 lg:px-8">
    <a href="/" class="group flex items-center space-x-3" aria-label="Ir al inicio">
      <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-linear-to-br from-blue-700 via-cyan-600 to-teal-500 shadow-lg shadow-blue-900/20 transition-transform group-hover:scale-105">
        <Rocket className="h-6 w-6 text-white" />
      </div>

      <div class="leading-tight">
        <span class="block bg-linear-to-r from-blue-900 to-teal-600 bg-clip-text text-2xl font-black tracking-tight text-transparent">
          ImpulsoWebLocal
        </span>
        <span class="hidden text-xs font-semibold uppercase tracking-[0.22em] text-slate-500 sm:block">
          Web + Google Ads
        </span>
      </div>
    </a>

    <div class="hidden lg:flex lg:items-center lg:space-x-1">
      {NAVIGATION.map((item) => {
        const isActive = isActiveLink(item.href);

        return (
          <a
            href={item.href}
            class={`group relative rounded-lg px-4 py-2 text-sm font-semibold text-slate-700 transition-all hover:bg-blue-50 hover:text-blue-700 ${isActive ? 'nav-active' : ''}`}
          >
            {item.name}
          </a>
        );
      })}
    </div>

    <div class="flex items-center gap-2 lg:gap-3">
      <a
        href={phoneHref}
        aria-label={`Llamar a Impulso Web Local ${phoneDisplay}`}
        class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-slate-950 text-white shadow-md transition-all hover:-translate-y-0.5 hover:bg-slate-800 hover:shadow-lg sm:w-auto sm:px-4 sm:py-2.5"
      >
        <Phone className="h-4 w-4" />
        <span class="ml-2 hidden text-sm font-bold sm:inline xl:hidden">
          Llamar
        </span>
        <span class="ml-2 hidden text-sm font-bold xl:inline">
          {phoneDisplay}
        </span>
      </a>

      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener"
        class="hidden items-center gap-2 rounded-xl bg-linear-to-r from-blue-700 to-teal-600 px-6 py-2.5 text-sm font-bold text-white shadow-md transition-all hover:-translate-y-0.5 hover:from-blue-800 hover:to-teal-700 hover:shadow-lg lg:inline-flex"
      >
        <span>Cotizar por WhatsApp</span>
        <MessageCircle className="h-4 w-4" />
      </a>

      <MobileMenu client:idle />
    </div>
  </nav>
</header>
