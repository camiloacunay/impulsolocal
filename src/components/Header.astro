---
import { NAVIGATION, SITE } from '@config/site';
import { Rocket } from 'lucide-react';
import MobileMenu from '@components/react/MobileMenu';

const { currentPathname } = Astro.props;
const normalize = (path: string) => path.endsWith('/') && path !== '/' ? path.slice(0, -1) : path;
const isActiveLink = (href: string): boolean => normalize(href) === normalize(currentPathname);
const whatsappUrl = `https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent('Hola, quiero cotizar una página web profesional con Google Ads')}`;
---

<header class="sticky top-0 z-50 w-full border-b border-slate-200 bg-white/95 backdrop-blur-md shadow-sm">
  <nav class="container mx-auto flex h-20 items-center justify-between px-4 sm:px-6 lg:px-8">
    <a href="/" class="flex items-center space-x-3 group" aria-label="Ir al inicio">
      <div class="flex items-center justify-center w-11 h-11 rounded-xl bg-linear-to-br from-blue-700 via-cyan-600 to-teal-500 group-hover:scale-105 transition-transform shadow-lg shadow-blue-900/20">
        <Rocket className="w-6 h-6 text-white" />
      </div>
      <div class="leading-tight">
        <span class="block text-2xl font-black tracking-tight bg-linear-to-r from-blue-900 to-teal-600 bg-clip-text text-transparent">ImpulsoLocal</span>
        <span class="hidden sm:block text-xs font-semibold text-slate-500 uppercase tracking-[0.22em]">Web + Google Ads</span>
      </div>
    </a>

    <div class="hidden lg:flex lg:items-center lg:space-x-1">
      {NAVIGATION.map((item) => {
        const isActive = isActiveLink(item.href);
        return (
          <a
            href={item.href}
            class={`px-4 py-2 text-sm font-semibold text-slate-700 hover:text-blue-700 hover:bg-blue-50 rounded-lg transition-all relative group ${isActive ? 'nav-active' : ''}`}
          >
            {item.name}
          </a>
        );
      })}
    </div>

    <div class="hidden lg:flex lg:items-center lg:space-x-4">
      <a href={whatsappUrl} target="_blank" rel="noopener" class="inline-flex items-center px-6 py-2.5 text-sm font-bold text-white bg-linear-to-r from-blue-700 to-teal-600 hover:from-blue-800 hover:to-teal-700 rounded-xl shadow-md hover:shadow-lg transition-all">
        Cotizar por WhatsApp
      </a>
    </div>

    <MobileMenu client:idle />
  </nav>
</header>
