---
import BaseLayout from '@layouts/BaseLayout.astro';
import { SITE } from '@config/site';
import { BadgeCheck, MessageCircle, ShieldCheck } from 'lucide-react';
const whatsappUrl = `https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent('Hola, quiero el pack inicial de página web profesional + Google Ads')}`;
---
<BaseLayout title="Precios | ImpulsoLocal" description="Pack inicial para página web profesional y configuración de Google Ads.">
  <section class="bg-slate-950 py-24 text-white">
    <div class="container mx-auto px-4 text-center sm:px-6 lg:px-8">
      <span class="text-sm font-black uppercase tracking-[0.25em] text-cyan-300">Precio claro</span>
      <h1 class="mx-auto mt-4 max-w-4xl text-5xl font-black tracking-tight sm:text-6xl">Pack inicial para empezar a captar clientes desde Google.</h1>
      <p class="mx-auto mt-6 max-w-2xl text-xl text-slate-300">La página queda para el cliente y la inversión publicitaria se paga directamente a Google.</p>
    </div>
  </section>

  <section class="py-24 bg-slate-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-4xl rounded-[2rem] border border-slate-200 bg-white p-8 shadow-2xl md:p-12">
        <div class="flex flex-col gap-8 md:flex-row md:items-end md:justify-between">
          <div>
            <span class="inline-flex rounded-full bg-blue-100 px-4 py-2 text-sm font-black text-blue-700">Pack Captación Local</span>
            <h2 class="mt-5 text-6xl font-black text-slate-950">$49.990</h2>
            <p class="mt-3 text-slate-600">Pago único por configuración inicial.</p>
          </div>
          <ShieldCheck className="w-20 h-20 text-emerald-600" />
        </div>

        <div class="mt-10 grid gap-6 md:grid-cols-2">
          <ul class="space-y-4">
            <li class="flex gap-3"><BadgeCheck className="w-6 h-6 text-emerald-600 shrink-0" /> Página web profesional para tu negocio.</li>
            <li class="flex gap-3"><BadgeCheck className="w-6 h-6 text-emerald-600 shrink-0" /> Botón directo a WhatsApp y llamada.</li>
            <li class="flex gap-3"><BadgeCheck className="w-6 h-6 text-emerald-600 shrink-0" /> Secciones de servicios y zonas de atención.</li>
          </ul>
          <ul class="space-y-4">
            <li class="flex gap-3"><BadgeCheck className="w-6 h-6 text-emerald-600 shrink-0" /> Configuración inicial de Google Ads.</li>
            <li class="flex gap-3"><BadgeCheck className="w-6 h-6 text-emerald-600 shrink-0" /> Revisión inicial de resultados.</li>
            <li class="flex gap-3"><BadgeCheck className="w-6 h-6 text-emerald-600 shrink-0" /> Recomendaciones para mejorar captación.</li>
          </ul>
        </div>

        <div class="mt-10 rounded-2xl bg-slate-100 p-6 text-slate-700">
          <b class="text-slate-950">Importante:</b> el presupuesto de Google Ads lo define y paga el cliente directamente a Google. No debes entregar datos bancarios a terceros.
        </div>

        <a href={whatsappUrl} target="_blank" rel="noopener" class="mt-10 inline-flex w-full items-center justify-center gap-2 rounded-xl bg-slate-950 px-7 py-4 text-base font-black text-white transition hover:bg-blue-900">
          Quiero este pack <MessageCircle className="w-5 h-5" />
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
