---
import BaseLayout from '@layouts/BaseLayout.astro';
import { ArrowRight, Camera, Home, Image, MapPin, Ruler } from 'lucide-react';
const projects = [
  { title: 'Cambio de techumbre', place: 'Rancagua', metric: '120 m²' },
  { title: 'Reparación de goteras', place: 'Machalí', metric: '48 hrs' },
  { title: 'Instalación canaletas', place: 'San Fernando', metric: 'Garantía' },
];
---
<BaseLayout title="Demo portfolio techumbres | ImpulsoLocal" description="Demo de portfolio para mostrar trabajos realizados.">
  <section class="bg-neutral-950 text-white">
    <div class="container mx-auto px-4 py-24 sm:px-6 lg:px-8">
      <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:items-end">
        <div>
          <div class="inline-flex h-16 w-16 items-center justify-center rounded-2xl bg-red-600"><Home className="w-9 h-9" /></div>
          <h1 class="mt-8 text-5xl font-black tracking-tight sm:text-7xl">Portfolio de techumbres y reparaciones</h1>
        </div>
        <p class="text-xl leading-8 text-neutral-300">Una página tipo portfolio sirve para mostrar experiencia, fotos de trabajos y resultados antes/después. Ideal para rubros visuales.</p>
      </div>
      <div class="mt-16 grid gap-6 md:grid-cols-3">
        {projects.map((project, index) => (
          <article class="group overflow-hidden rounded-[2rem] bg-white text-neutral-950 shadow-2xl">
            <div class={`h-64 ${index === 0 ? 'bg-red-700' : index === 1 ? 'bg-stone-700' : 'bg-orange-600'} flex items-center justify-center`}><Camera className="w-16 h-16 text-white/90" /></div>
            <div class="p-7">
              <h2 class="text-2xl font-black">{project.title}</h2>
              <div class="mt-5 flex items-center justify-between text-sm text-neutral-600"><span class="flex items-center gap-2"><MapPin className="w-4 h-4" />{project.place}</span><span class="flex items-center gap-2"><Ruler className="w-4 h-4" />{project.metric}</span></div>
              <a href="#" class="mt-6 inline-flex items-center gap-2 font-black text-red-700">Ver proyecto <ArrowRight className="w-5 h-5" /></a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
