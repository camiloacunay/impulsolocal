---
import BaseLayout from '@layouts/BaseLayout.astro';
import {
  ArrowRight,
  BriefcaseBusiness,
  Building2,
  Camera,
  LayoutDashboard,
  Sparkles,
  Wrench,
  Home,
} from 'lucide-react';

const demos = [
  {
    href: 'https://pro-cleaning-eta.vercel.app/',
    image: '/assets/demos/pro-cleaning.png',
    icon: Sparkles,
    type: 'Servicios locales',
    title: 'Empresa de limpieza',
    text: 'Landing profesional para servicios de limpieza, con presentación clara, llamadas a la acción, secciones de servicios y enfoque comercial.',
  },
  {
    href: 'https://servigasfiter.cl/',
    image: '/assets/demos/servigasfiter.png',
    icon: Wrench,
    type: 'Landing de servicios',
    title: 'Gasfitería a domicilio',
    text: 'Página enfocada en captar clientes mediante WhatsApp, llamada directa y servicios urgentes como fugas, destapes, grifería y emergencias.',
  },
  {
    href: 'https://horizon.cosmicthemes.com/',
    image: '/assets/demos/horizon.png',
    icon: Camera,
    type: 'Portfolio visual',
    title: 'Fotografía y portafolio',
    text: 'Diseño visual y elegante para fotógrafos, artistas, marcas personales o negocios donde las imágenes son parte central de la venta.',
  },
  {
    href: 'https://free-sbs.netlify.app/',
    image: '/assets/demos/small-business.png',
    icon: BriefcaseBusiness,
    type: 'Pyme / servicios',
    title: 'Negocio de servicios',
    text: 'Sitio ideal para pequeñas empresas, contratistas, técnicos o profesionales que necesitan explicar sus servicios y generar confianza.',
  },
  {
    href: 'https://astropie.netlify.app/',
    image: '/assets/demos/astropie.png',
    icon: LayoutDashboard,
    type: 'Landing moderna',
    title: 'Web moderna para negocio',
    text: 'Ejemplo de sitio liviano, visual y moderno para emprendimientos, productos digitales, servicios online o presentación comercial.',
  },
  {
    href: 'https://3dinterior.mail-nearmelab.workers.dev/',
    image: '/assets/demos/interior-3d.png',
    icon: Home,
    type: 'Arquitectura / interiorismo',
    title: 'Arquitectura e interiores',
    text: 'Página premium para mostrar proyectos, trabajos realizados, servicios visuales, diseño de interiores o portafolios profesionales.',
  },
  {
    href: 'https://clay-astro-theme.netlify.app/',
    image: '/assets/demos/clay.png',
    icon: Building2,
    type: 'Theme / portafolio',
    title: 'Portfolio minimalista',
    text: 'Demo de estilo limpio y elegante para creativos, fotógrafos, artistas o negocios que necesitan una web visual de alto impacto.',
  },
];
---

<BaseLayout
  title="Demos de páginas web | ImpulsoLocal"
  description="Ejemplos reales de páginas web para negocios locales, servicios profesionales, portafolios, landing pages y sitios comerciales."
>
  <section class="bg-slate-950 py-24 text-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl">
        <span class="inline-flex items-center gap-2 rounded-full bg-cyan-300/10 px-4 py-2 text-sm font-black text-cyan-200">
          <Sparkles className="h-4 w-4" /> Demos reales para distintos tipos de negocio
        </span>

        <h1 class="mt-8 text-5xl font-black tracking-tight sm:text-6xl">
          Explora estilos reales para tu próxima página web.
        </h1>

        <p class="mt-6 max-w-3xl text-xl leading-8 text-slate-300">
          Revisa ejemplos de sitios para servicios locales, negocios profesionales,
          portafolios, landing pages y páginas enfocadas en captar clientes.
        </p>
      </div>
    </div>
  </section>

  <section class="py-24 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {demos.map((demo) => {
          const Icon = demo.icon;

          return (
            <a
              href={demo.href}
              target="_blank"
              rel="noopener noreferrer"
              class="group overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-xl"
            >
              <div class="aspect-[16/10] overflow-hidden bg-slate-100">
                <img
                  src={demo.image}
                  alt={`Vista previa de ${demo.title}`}
                  loading="lazy"
                  class="h-full w-full object-cover object-top transition duration-300 group-hover:scale-105"
                />
              </div>

              <div class="p-7">
                <div class="flex items-center justify-between gap-4">
                  <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br from-blue-700 to-teal-600 text-white">
                    <Icon className="h-7 w-7" />
                  </div>

                  <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-black uppercase tracking-wider text-slate-600">
                    {demo.type}
                  </span>
                </div>

                <h2 class="mt-7 text-2xl font-black text-slate-950">
                  {demo.title}
                </h2>

                <p class="mt-4 text-slate-600 leading-7">
                  {demo.text}
                </p>

                <span class="mt-6 inline-flex items-center gap-2 font-black text-blue-700">
                  Ver demo <ArrowRight className="h-5 w-5 transition group-hover:translate-x-1" />
                </span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>
</BaseLayout>
