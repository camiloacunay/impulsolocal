---
import BaseLayout from '@layouts/BaseLayout.astro';
import { BookOpen, CalendarDays, Droplets, Flame, Home, Newspaper, Search } from 'lucide-react';
const posts = [
  { tag: 'Gasfitería', title: 'Cómo detectar una fuga de agua antes de que sea grave', icon: Droplets },
  { tag: 'Calefacción', title: 'Mantención de calefont: señales de alerta', icon: Flame },
  { tag: 'Hogar', title: 'Checklist mensual para mantener tu casa segura', icon: Home },
];
---
<BaseLayout title="Demo blog magazine | ImpulsoLocal" description="Demo de blog o magazine para atraer tráfico con contenido.">
  <section class="bg-lime-50">
    <div class="container mx-auto px-4 py-8 sm:px-6 lg:px-8">
      <nav class="flex flex-col gap-4 border-b border-lime-200 pb-6 md:flex-row md:items-center md:justify-between">
        <div class="flex items-center gap-3"><div class="flex h-12 w-12 items-center justify-center rounded-full bg-lime-700 text-white"><Newspaper className="w-7 h-7" /></div><b class="text-2xl text-lime-950">CasaPráctica</b></div>
        <div class="flex items-center gap-3 rounded-full bg-white px-5 py-3 shadow-sm"><Search className="w-5 h-5 text-lime-700" /><span class="text-sm text-slate-500">Buscar consejos</span></div>
      </nav>
    </div>
    <div class="container mx-auto px-4 pb-24 pt-10 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-4xl text-center">
        <span class="text-sm font-black uppercase tracking-[0.25em] text-lime-700">Blog / Magazine</span>
        <h1 class="mt-5 text-5xl font-black tracking-tight text-lime-950 sm:text-7xl">Consejos útiles para cuidar el hogar</h1>
        <p class="mt-6 text-xl leading-8 text-lime-900/70">Una web de contenido permite educar, posicionar la marca y atraer visitas orgánicas desde Google.</p>
      </div>
      <div class="mt-16 grid gap-8 md:grid-cols-3">
        {posts.map((post) => {
          const Icon = post.icon;
          return (
            <article class="rounded-[2rem] bg-white p-7 shadow-sm transition hover:-translate-y-1 hover:shadow-xl">
              <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-lime-100 text-lime-700"><Icon className="w-7 h-7" /></div>
              <p class="mt-6 text-sm font-black uppercase tracking-wider text-lime-700">{post.tag}</p>
              <h2 class="mt-3 text-2xl font-black text-lime-950">{post.title}</h2>
              <div class="mt-6 flex items-center gap-3 text-sm text-slate-500"><CalendarDays className="w-4 h-4" /> Artículo destacado</div>
              <a href="#" class="mt-6 inline-flex items-center gap-2 font-black text-lime-700"><BookOpen className="w-5 h-5" /> Leer más</a>
            </article>
          );
        })}
      </div>
    </div>
  </section>
</BaseLayout>
