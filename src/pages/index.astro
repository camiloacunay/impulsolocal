---
import BaseLayout from '@layouts/BaseLayout.astro';
import { SITE } from '@config/site';
import { ArrowRight, BadgeCheck, BarChart3, ExternalLink, Globe2, MessageCircle, MousePointerClick, Phone, Search, ShieldCheck, Sparkles, Star, Zap } from 'lucide-react';
import heroImage from '@assets/photo-1551288049-bebda4e38f71.jpg';
import teamImage from '@assets/photo-1522071820081-009f0129c71c.jpg';

const phoneRaw = SITE.whatsapp.replace(/\D/g, '');
const phoneHref = `tel:+${phoneRaw}`;

const phoneDisplay =
  phoneRaw.startsWith('56') && phoneRaw.length === 11
    ? `+${phoneRaw.slice(0, 2)} ${phoneRaw.slice(2, 3)} ${phoneRaw.slice(3, 7)} ${phoneRaw.slice(7)}`
    : `+${phoneRaw}`;

const whatsappUrl = `https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent('Hola, quiero cotizar una página web profesional con Google Ads')}`;

const services = [
  { icon: Globe2, title: 'Página web profesional', text: 'Diseñada para transmitir confianza, explicar tus servicios y convertir visitas en mensajes por WhatsApp.' },
  { icon: Search, title: 'Google Ads local', text: 'Campañas para aparecer cuando alguien busca tu servicio en tu ciudad, como gasfíter, electricista o cerrajero.' },
  { icon: BarChart3, title: 'Revisión de resultados', text: 'Medimos clics, consultas y oportunidades para saber qué anuncios funcionan mejor.' },
];

const niches = ['Gasfíteres', 'Electricistas', 'Cerrajeros', 'Control de plagas', 'Climatización', 'Reparación de electrodomésticos', 'Techumbres', 'Mecánica automotriz'];

const realClients = [
  {
    name: 'ServiGasfíter',
    type: 'Gasfitería a domicilio',
    href: '/clientes/servigasfiter/',
    image: '/clientes/servigasfiter/assets/og-image.png',
    text: 'Web profesional para fugas, destapes, calefont y servicios sanitarios con contacto directo por WhatsApp.',
  },
  {
    name: 'FullCerrajería 24Hrs',
    type: 'Cerrajería 24/7',
    href: '/clientes/fullcerrajeria24hrs/',
    image: '/clientes/fullcerrajeria24hrs/assets/img/og-image.jpg',
    text: 'Sitio enfocado en urgencias, aperturas, vehículos, llaves con chip y zonas de atención en la V Región.',
  },
];

const withBase = (path: string) => `${import.meta.env.BASE_URL}${path.replace(/^\/+/, '')}`;
---

<BaseLayout title="ImpulsoLocal | Páginas web profesionales + Google Ads" description="Creamos páginas web profesionales y configuramos Google Ads para negocios locales que quieren recibir más consultas por WhatsApp o llamada.">
  <section class="relative overflow-hidden bg-slate-950">
    <div class="absolute inset-0 opacity-40 bg-[radial-gradient(circle_at_top_left,_#1d4ed8,_transparent_35%),radial-gradient(circle_at_bottom_right,_#0f766e,_transparent_40%)]"></div>
    
    <div class="container relative mx-auto grid min-h-[760px] grid-cols-1 items-center gap-14 px-4 py-24 sm:px-6 lg:grid-cols-2 lg:px-8">
      <div class="max-w-3xl">
        <span class="inline-flex items-center gap-2 rounded-full border border-cyan-300/30 bg-cyan-300/10 px-4 py-2 text-sm font-bold text-cyan-200">
          <Sparkles className="w-4 h-4" /> Web + Google Ads para servicios locales
        </span>

        <h1 class="mt-8 text-5xl font-black tracking-tight text-white sm:text-6xl lg:text-7xl">
          Consigue más clientes desde Google con una web que venda.
        </h1>

        <p class="mt-7 text-xl leading-8 text-slate-300">
          Creamos páginas web profesionales para negocios de servicios y configuramos Google Ads para que puedan aparecer cuando una persona busca exactamente lo que ofrecen.
        </p>

        <div class="mt-10 flex flex-col gap-4 sm:flex-row sm:flex-wrap">
          <a
            href={phoneHref}
            aria-label={`Llamar a Impulso Web Local ${phoneDisplay}`}
            class="inline-flex items-center justify-center gap-2 rounded-xl bg-slate-950 px-7 py-4 text-base font-black text-white shadow-xl ring-1 ring-white/20 transition hover:-translate-y-0.5 hover:bg-slate-800"
          >
            Llamar ahora <Phone className="w-5 h-5" />
          </a>

          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center justify-center gap-2 rounded-xl bg-white px-7 py-4 text-base font-black text-slate-950 shadow-xl transition hover:-translate-y-0.5 hover:bg-cyan-50"
          >
            Cotizar por WhatsApp <MessageCircle className="w-5 h-5" />
          </a>

          <a
            href="/demos"
            class="inline-flex items-center justify-center gap-2 rounded-xl border border-white/20 bg-white/10 px-7 py-4 text-base font-black text-white backdrop-blur transition hover:bg-white/20"
          >
            Ver demos reales <ArrowRight className="w-5 h-5" />
          </a>
        </div>

        <div class="mt-12 grid grid-cols-3 gap-5 border-t border-white/10 pt-8">
          <div>
            <p class="text-3xl font-black text-white">$49.990</p>
            <p class="text-sm text-slate-400">Pack inicial</p>
          </div>
          <div>
            <p class="text-3xl font-black text-white">24/7</p>
            <p class="text-sm text-slate-400">Web activa</p>
          </div>
          <div>
            <p class="text-3xl font-black text-white">Google</p>
            <p class="text-sm text-slate-400">Búsquedas reales</p>
          </div>
        </div>
      </div>

      <div class="relative">
        <div class="absolute -inset-6 rounded-[2rem] bg-linear-to-br from-cyan-400/20 to-blue-600/20 blur-2xl"></div>
        
        <div class="relative overflow-hidden rounded-[2rem] border border-white/10 bg-white/10 p-3 shadow-2xl backdrop-blur">
          <img src={heroImage.src} alt="Panel de resultados y publicidad digital" class="h-[520px] w-full rounded-[1.5rem] object-cover opacity-90" />
          
          <div class="absolute bottom-8 left-8 right-8 rounded-2xl bg-white/95 p-5 shadow-2xl">
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="text-sm font-bold uppercase tracking-wider text-blue-700">Sistema de captación</p>
                <h2 class="mt-1 text-2xl font-black text-slate-950">Web + WhatsApp + Google Ads</h2>
              </div>
              <span class="rounded-full bg-emerald-100 px-3 py-1 text-xs font-black text-emerald-700">Listo para vender</span>
            </div>
            
            <div class="mt-5 grid grid-cols-3 gap-3 text-center text-sm">
              <div class="rounded-xl bg-slate-100 p-3"><b class="block text-slate-950">1</b>Te encuentran</div>
              <div class="rounded-xl bg-slate-100 p-3"><b class="block text-slate-950">2</b>Ven tu web</div>
              <div class="rounded-xl bg-slate-100 p-3"><b class="block text-slate-950">3</b>Te escriben</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <span class="text-sm font-black uppercase tracking-[0.25em] text-blue-700">Lo que ofrecemos</span>
        <h2 class="mt-4 text-4xl font-black tracking-tight text-slate-950 sm:text-5xl">No es solo una página bonita. Es una herramienta para generar consultas.</h2>
        <p class="mt-6 text-lg text-slate-600">Diseñamos la web pensando en conversiones: llamada, WhatsApp, formulario y confianza antes de invertir en publicidad.</p>
      </div>

      <div class="mt-16 grid gap-8 md:grid-cols-3">
        {services.map((service) => {
          const Icon = service.icon;

          return (
            <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm transition hover:-translate-y-1 hover:shadow-xl">
              <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-linear-to-br from-blue-700 to-teal-600 text-white shadow-lg">
                <Icon className="w-7 h-7" />
              </div>
              <h3 class="mt-7 text-2xl font-black text-slate-950">{service.title}</h3>
              <p class="mt-4 text-slate-600 leading-7">{service.text}</p>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <section class="bg-slate-50 py-24">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-end">
        <div>
          <span class="inline-flex items-center gap-2 rounded-full bg-blue-100 px-4 py-2 text-sm font-black text-blue-800">
            <Star className="w-4 h-4" /> Clientes reales
          </span>

          <h2 class="mt-6 text-4xl font-black tracking-tight text-slate-950 sm:text-5xl">
            Negocios que ya confían en nuestras páginas web.
          </h2>

          <p class="mt-6 text-lg leading-8 text-slate-600">
            Además de demos, mostramos trabajos reales publicados. Cada página tiene identidad propia,
            mensajes adaptados al rubro y llamados claros a WhatsApp o llamada.
          </p>

          <a
            href={withBase('clientes/')}
            class="mt-8 inline-flex items-center gap-2 rounded-xl bg-slate-950 px-7 py-4 text-base font-black text-white transition hover:bg-blue-900"
          >
            Ver clientes reales <ArrowRight className="w-5 h-5" />
          </a>
        </div>

        <div class="grid gap-6 md:grid-cols-2">
          <a
            href={withBase('clientes/servigasfiter/')}
            class="group overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-2xl"
          >
            <div class="relative h-56 overflow-hidden bg-slate-100">
              <iframe
                src={withBase('clientes/servigasfiter/')}
                title="Vista previa de ServiGasfíter"
                loading="lazy"
                class="pointer-events-none absolute left-0 top-0 h-[180%] w-[180%] origin-top-left scale-[0.56] border-0 bg-white"
              ></iframe>

              <span class="absolute right-5 top-5 rounded-full bg-white/95 px-3 py-1 text-xs font-black uppercase tracking-wider text-slate-800 shadow">
                Gasfitería a domicilio
              </span>
            </div>

            <div class="p-6">
              <h3 class="text-2xl font-black text-slate-950">ServiGasfíter</h3>

              <p class="mt-3 leading-7 text-slate-600">
                Web profesional para fugas, destapes, calefont y servicios sanitarios con contacto directo por WhatsApp.
              </p>

              <span class="mt-5 inline-flex items-center gap-2 font-black text-blue-700">
                Abrir página <ExternalLink className="w-4 h-4 transition group-hover:translate-x-1" />
              </span>
            </div>
          </a>

          <a
            href={withBase('clientes/fullcerrajeria24hrs/')}
            class="group overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-2xl"
          >
            <div class="relative h-56 overflow-hidden bg-slate-100">
              <iframe
                src={withBase('clientes/fullcerrajeria24hrs/')}
                title="Vista previa de FullCerrajería 24Hrs"
                loading="lazy"
                class="pointer-events-none absolute left-0 top-0 h-[180%] w-[180%] origin-top-left scale-[0.56] border-0 bg-white"
              ></iframe>

              <span class="absolute right-5 top-5 rounded-full bg-white/95 px-3 py-1 text-xs font-black uppercase tracking-wider text-slate-800 shadow">
                Cerrajería 24/7
              </span>
            </div>

            <div class="p-6">
              <h3 class="text-2xl font-black text-slate-950">FullCerrajería 24Hrs</h3>

              <p class="mt-3 leading-7 text-slate-600">
                Sitio enfocado en urgencias, aperturas, vehículos, llaves con chip y zonas de atención en la V Región.
              </p>

              <span class="mt-5 inline-flex items-center gap-2 font-black text-blue-700">
                Abrir página <ExternalLink className="w-4 h-4 transition group-hover:translate-x-1" />
              </span>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-slate-50 py-24">
    <div class="container mx-auto grid grid-cols-1 items-center gap-14 px-4 sm:px-6 lg:grid-cols-2 lg:px-8">
      <div class="relative overflow-hidden rounded-[2rem] demo-shadow">
        <img src={teamImage.src} alt="Equipo trabajando estrategia digital" class="h-[520px] w-full object-cover" />
        <div class="absolute inset-0 bg-linear-to-t from-slate-950/85 via-slate-950/10 to-transparent"></div>
        <div class="absolute bottom-8 left-8 right-8 text-white">
          <p class="text-sm font-bold uppercase tracking-wider text-cyan-200">Método comercial</p>
          <h2 class="mt-2 text-3xl font-black">Captamos a personas que ya están buscando contratar.</h2>
        </div>
      </div>

      <div>
        <span class="text-sm font-black uppercase tracking-[0.25em] text-teal-700">Para negocios locales</span>
        <h2 class="mt-4 text-4xl font-black tracking-tight text-slate-950 sm:text-5xl">Especializado en servicios con búsqueda urgente o alta intención.</h2>
        <p class="mt-6 text-lg leading-8 text-slate-600">Tu cliente ideal no siempre está en redes sociales. Muchas veces está en Google escribiendo “cerca de mí”, “urgente”, “24 horas” o el nombre de la ciudad.</p>
        
        <div class="mt-8 flex flex-wrap gap-3">
          {niches.map((niche) => (
            <span class="rounded-full bg-white px-4 py-2 text-sm font-bold text-slate-700 shadow-sm ring-1 ring-slate-200">
              {niche}
            </span>
          ))}
        </div>

        <a href="/servicios" class="mt-10 inline-flex items-center gap-2 rounded-xl bg-slate-950 px-7 py-4 text-base font-black text-white transition hover:bg-blue-900">
          Ver servicios <ArrowRight className="w-5 h-5" />
        </a>
      </div>
    </div>
  </section>

  <section class="py-24 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 lg:grid-cols-4">
        <div class="lg:col-span-1">
          <span class="text-sm font-black uppercase tracking-[0.25em] text-blue-700">Proceso</span>
          <h2 class="mt-4 text-4xl font-black text-slate-950">De publicación informal a captación profesional.</h2>
        </div>

        <div class="lg:col-span-3 grid gap-6 md:grid-cols-3">
          <div class="rounded-3xl bg-slate-950 p-8 text-white">
            <MousePointerClick className="w-8 h-8 text-cyan-300" />
            <h3 class="mt-5 text-xl font-black">1. Diseñamos tu web</h3>
            <p class="mt-3 text-slate-300">Servicios claros, botón a WhatsApp, zonas de atención y estructura profesional.</p>
          </div>

          <div class="rounded-3xl bg-blue-700 p-8 text-white">
            <Zap className="w-8 h-8 text-cyan-200" />
            <h3 class="mt-5 text-xl font-black">2. Activamos Google Ads</h3>
            <p class="mt-3 text-blue-100">Creamos anuncios para búsquedas relevantes en tu ciudad o región.</p>
          </div>

          <div class="rounded-3xl bg-teal-700 p-8 text-white">
            <ShieldCheck className="w-8 h-8 text-cyan-100" />
            <h3 class="mt-5 text-xl font-black">3. Revisamos resultados</h3>
            <p class="mt-3 text-teal-50">Observamos clics, contactos y oportunidades para optimizar.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-slate-950 py-24 text-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
        <div>
          <span class="text-sm font-black uppercase tracking-[0.25em] text-cyan-300">Pack inicial</span>
          <h2 class="mt-4 text-5xl font-black tracking-tight">Empieza con una inversión clara.</h2>
          <p class="mt-6 text-xl text-slate-300">Ideal para probar una presencia profesional en Google sin compromisos largos desde el primer día.</p>
        </div>

        <div class="rounded-[2rem] border border-white/10 bg-white/10 p-8 backdrop-blur">
          <div class="flex items-end justify-between gap-6">
            <div>
              <p class="text-sm font-black uppercase tracking-wider text-cyan-300">Pack Captación Local</p>
              <p class="mt-2 text-5xl font-black">$49.990</p>
            </div>
            <BadgeCheck className="w-14 h-14 text-emerald-300" />
          </div>

          <ul class="mt-8 space-y-4 text-slate-200">
            <li class="flex gap-3"><BadgeCheck className="w-5 h-5 text-emerald-300 shrink-0" /> Página web profesional para tu negocio</li>
            <li class="flex gap-3"><BadgeCheck className="w-5 h-5 text-emerald-300 shrink-0" /> Botón directo a WhatsApp y llamada</li>
            <li class="flex gap-3"><BadgeCheck className="w-5 h-5 text-emerald-300 shrink-0" /> Configuración inicial de Google Ads</li>
            <li class="flex gap-3"><BadgeCheck className="w-5 h-5 text-emerald-300 shrink-0" /> Revisión inicial de resultados</li>
          </ul>

          <p class="mt-6 rounded-2xl bg-white/10 p-4 text-sm text-slate-300">La página queda para el cliente. La inversión publicitaria se paga directamente a Google con el presupuesto definido por el cliente.</p>

          <div class="mt-8 grid gap-3 sm:grid-cols-2">
            <a
              href={phoneHref}
              aria-label={`Llamar a Impulso Web Local ${phoneDisplay}`}
              class="inline-flex w-full items-center justify-center gap-2 rounded-xl bg-slate-950 px-7 py-4 text-base font-black text-white ring-1 ring-white/15 transition hover:bg-slate-800"
            >
              Llamar ahora <Phone className="w-5 h-5" />
            </a>

            <a
              href={whatsappUrl}
              target="_blank"
              rel="noopener"
              class="inline-flex w-full items-center justify-center gap-2 rounded-xl bg-white px-7 py-4 text-base font-black text-slate-950 transition hover:bg-cyan-50"
            >
              Solicitar pack <ArrowRight className="w-5 h-5" />
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
