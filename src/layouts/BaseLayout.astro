---
import '../styles/global.css';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import { SITE } from '@config/site';

interface Props {
  title?: string;
  description?: string;
}

const currentPathname = Astro.url.pathname;
const { title = SITE.title, description = SITE.description } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <!-- Google tag (gtag.js) - Google Ads + Google Analytics GA4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=AW-18247724039"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      /* Google Ads */
      gtag('config', 'AW-18247724039');

      /* Google Analytics 4 */
      gtag('config', 'G-L7QHYM4WQD');
    </script>

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
  </head>

  <body class="flex min-h-screen flex-col bg-white font-sans text-neutral-900 antialiased">
    <Header currentPathname={currentPathname} />

    <main class="flex-1">
      <slot />
    </main>

    <Footer />

    <!-- Eventos personalizados para medir conversiones en GA4 -->
    <script is:inline>
      document.addEventListener("DOMContentLoaded", () => {
        function enviarEventoGA(nombreEvento, parametros = {}) {
          if (typeof gtag === "function") {
            gtag("event", nombreEvento, {
              event_category: "conversion",
              ...parametros,
              transport_type: "beacon"
            });
          }
        }

        function obtenerTexto(link) {
          return link.textContent ? link.textContent.trim().replace(/\s+/g, " ") : "";
        }

        function esWhatsapp(link) {
          return link.href.includes("wa.me") || link.href.includes("api.whatsapp.com");
        }

        function esTelefono(link) {
          return link.href.startsWith("tel:");
        }

        // Clics en WhatsApp
        document
          .querySelectorAll('a[href*="wa.me"], a[href*="api.whatsapp.com"]')
          .forEach((link) => {
            link.addEventListener("click", () => {
              enviarEventoGA("click_whatsapp", {
                event_label: link.href,
                click_text: obtenerTexto(link),
                page_path: window.location.pathname
              });
            });
          });

        // Clics en teléfono
        document.querySelectorAll('a[href^="tel:"]').forEach((link) => {
          link.addEventListener("click", () => {
            enviarEventoGA("click_llamada", {
              event_label: link.href,
              click_text: obtenerTexto(link),
              page_path: window.location.pathname
            });
          });
        });

        // Clics en botones de cotización/contacto
        document
          .querySelectorAll('a[href="#contacto"], a[href*="contacto"], a[href*="cotizar"], .btn-cotizar')
          .forEach((link) => {
            link.addEventListener("click", () => {
              if (esWhatsapp(link) || esTelefono(link)) return;

              enviarEventoGA("click_cotizar", {
                event_label: link.href || "boton_cotizar",
                click_text: obtenerTexto(link),
                page_path: window.location.pathname
              });
            });
          });

        // Clics en demos
        document
          .querySelectorAll('a[href*="/demos"], a[href*="demo"], .demo-card a')
          .forEach((link) => {
            link.addEventListener("click", () => {
              if (esWhatsapp(link) || esTelefono(link)) return;

              enviarEventoGA("click_demo", {
                event_label: link.href,
                click_text: obtenerTexto(link),
                page_path: window.location.pathname
              });
            });
          });

        // Envíos de formularios
        document.querySelectorAll("form").forEach((form) => {
          form.addEventListener("submit", () => {
            enviarEventoGA("formulario_contacto", {
              event_label: form.id || "formulario_sin_id",
              page_path: window.location.pathname
            });
          });
        });
      });
    </script>
  </body>
</html>
